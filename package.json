{
  "name": "pixel-editor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @pixel-editor/web",
    "build": "npm run build --workspace @pixel-editor/web",
    "lint": "npm run lint --workspace @pixel-editor/web",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.4",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
