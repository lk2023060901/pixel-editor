{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useDefineForClassFields": true,
    "verbatimModuleSyntax": true,
    "allowJs": false,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "declaration": false,
    "baseUrl": ".",
    "paths": {
      "@pixel-editor/contracts": ["packages/contracts/src/index.ts"],
      "@pixel-editor/domain": ["packages/domain/src/index.ts"],
      "@pixel-editor/example-project-support": ["packages/example-project-support/src/index.ts"],
      "@pixel-editor/export-jobs": ["packages/export-jobs/src/index.ts"],
      "@pixel-editor/i18n": ["packages/i18n/src/index.ts"],
      "@pixel-editor/i18n/client": ["packages/i18n/src/client.tsx"],
      "@pixel-editor/command-engine": ["packages/command-engine/src/index.ts"],
      "@pixel-editor/asset-reference": ["packages/asset-reference/src/index.ts"],
      "@pixel-editor/automapping": ["packages/automapping/src/index.ts"],
      "@pixel-editor/editor-state": ["packages/editor-state/src/index.ts"],
      "@pixel-editor/project": ["packages/project/src/index.ts"],
      "@pixel-editor/template": ["packages/template/src/index.ts"],
      "@pixel-editor/world": ["packages/world/src/index.ts"],
      "@pixel-editor/app-services": ["packages/app-services/src/index.ts"],
      "@pixel-editor/app-services/ui": ["packages/app-services/src/ui.ts"],
      "@pixel-editor/app-services/ui-custom-properties": ["packages/app-services/src/ui-custom-properties.ts"],
      "@pixel-editor/app-services/ui-property-types": ["packages/app-services/src/ui-property-types.ts"],
      "@pixel-editor/app-services/ui-tiles": ["packages/app-services/src/ui-tiles.ts"],
      "@pixel-editor/map": ["packages/map/src/index.ts"],
      "@pixel-editor/objects": ["packages/objects/src/index.ts"],
      "@pixel-editor/tileset": ["packages/tileset/src/index.ts"],
      "@pixel-editor/tiled-project": ["packages/tiled-project/src/index.ts"],
      "@pixel-editor/tiled-world": ["packages/tiled-world/src/index.ts"],
      "@pixel-editor/tiled-automapping": ["packages/tiled-automapping/src/index.ts"],
      "@pixel-editor/tiled-json": ["packages/tiled-json/src/index.ts"],
      "@pixel-editor/tiled-xml": ["packages/tiled-xml/src/index.ts"],
      "@pixel-editor/renderer-pixi": ["packages/renderer-pixi/src/index.ts"],
      "@pixel-editor/ui-editor": ["packages/ui-editor/src/index.ts"]
    }
  }
}
